# PostgreSQL (Supabase — connection string do dashboard)
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# Supabase Auth (obrigatorio)
# Obtenha em: Supabase Dashboard > Settings > API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua_service_role_key_aqui
SUPABASE_JWT_SECRET=sua_jwt_secret_aqui

# OpenAI (embeddings + LLM)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# LLM Provider: "openai" ou "anthropic"
LLM_PROVIDER=openai

# Anthropic (Claude) — opcional se LLM_PROVIDER=openai
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# GitHub Webhooks (opcional — para re-indexacao automatica)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Criptografia de API keys dos provedores LLM (Fernet)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: Perder esta chave torna as API keys salvas inacessiveis
LLM_ENCRYPTION_KEY=

# CORS — dominios permitidos separados por virgula
# Em producao: https://seuapp.vercel.app,https://seudominio.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# URL publica da aplicacao (frontend) — usada em links de notificacao
APP_URL=http://localhost:3000

# URL publica da API (usada pelo frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Email SMTP (opcional — para notificacoes por email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Ambiente: development ou production
APP_ENV=development
